# Discord Bot Tokens（從 Discord Developer Portal 取得，三個 bot 各自一個 token）
BOT_TOKEN_A=your_bot_a_token_here
BOT_TOKEN_B=your_bot_b_token_here
BOT_TOKEN_C=your_bot_c_token_here

# Claude CLI 路徑（VPS 上通常是 /usr/bin/claude 或 /usr/local/bin/claude）
CLAUDE_PATH=/usr/bin/claude

# SQLite 資料庫路徑（所有 bot 行程與 dashboard 共用）
ADDWII_DB_PATH=/opt/addwii-pm/data/addwii.db

# 環境（dev / prod）
ENV=dev

# AIMOS LACP 對接設定（tools/aimos_client.py 使用）
AIMOS_BASE_URL=http://192.168.23.186:8560
AIMOS_LINGCE_KEY=向 AIMOS 端索取你的 X-LINGCE-KEY
